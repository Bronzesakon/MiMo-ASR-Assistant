{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiMo ASR Assistant",
  "version": "1.0.0",
  "identifier": "com.mimo.asr.assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MiMo ASR Assistant",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "center": true,
        "maximized": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/ffmpeg.exe",
      "WebView2Loader.dll"
    ]
  }
}
